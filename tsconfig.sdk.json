{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.sdk.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "./sdk-js/src",
    "outDir": "./sdk-js/dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "stripInternal": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "composite": true
  },
  "include": ["sdk-js/src/**/*.ts"]
}
